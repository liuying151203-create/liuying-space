---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeader from '@/components/common/SectionHeader.astro';
import Timeline from '@/components/shared/Timeline.astro';
import { profile } from '@/data/profile';
import { skillGroups } from '@/data/skills';
import { timeline } from '@/data/timeline';
import { withBase } from '@/utils/url';
---

<BaseLayout title="About | Liuying Space" description="Personal introduction, skills, and timeline.">
  <section class="section-shell py-16 sm:py-20">
    <SectionHeader title="About" description="Personal background, capabilities, and ways to get in touch." />
    <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="space-y-6">
        <div class="glass-card rounded-3xl p-6 sm:p-8">
          <div class="mb-5 grid size-24 place-items-center overflow-hidden rounded-2xl border border-white/10 bg-sky-400/10 text-3xl font-semibold text-sky-200">
            {profile.avatarImage ? <img src={withBase(profile.avatarImage)} alt={profile.avatarAlt} class="size-full object-cover" /> : profile.initials}
          </div>
          <h1 class="font-display text-3xl font-semibold text-white">{profile.name}</h1>
          <p class="mt-3 text-base leading-8 text-slate-300">{profile.summary}</p>
          <p class="mt-4 text-sm text-slate-400">{profile.location}</p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {skillGroups.map((group) => (
            <div class="glass-card rounded-3xl p-6">
              <h2 class="text-lg font-semibold text-white">{group.title}</h2>
              <div class="mt-4 flex flex-wrap gap-2">
                {group.items.map((item) => (
                  <span class="rounded-full border border-white/10 px-3 py-1 text-sm text-slate-300">{item}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="space-y-6">
        <SectionHeader title="Timeline" description="Learning and work milestones." />
        <Timeline items={timeline} />
        <div class="glass-card rounded-3xl p-6">
          <h2 class="text-lg font-semibold text-white">Contact</h2>
          <a href={`mailto:${profile.email}`} class="mt-3 block text-sky-300 hover:text-sky-200">
            {profile.email}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
