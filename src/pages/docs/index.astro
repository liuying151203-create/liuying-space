---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeader from '@/components/common/SectionHeader.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const docs = ((await getCollection('docs')) as CollectionEntry<'docs'>[])
  .filter((doc) => !doc.data.draft)
  .sort((a, b) => a.data.order - b.data.order || b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Docs | Liuying Space" description="Tutorials, notes, and documentation series.">
  <section class="section-shell py-16 sm:py-20">
    <SectionHeader title="Docs" description="Series-oriented tutorials and notes with room for chapters and sidebar navigation." />
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {docs.map((doc) => (
        <a href={`/docs/${doc.slug}/`} class="glass-card rounded-3xl p-6 transition-transform hover:-translate-y-1">
          <p class="text-sm text-slate-400">{doc.data.category}</p>
          <h3 class="mt-2 text-xl font-semibold text-white">{doc.data.title}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-300">{doc.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
