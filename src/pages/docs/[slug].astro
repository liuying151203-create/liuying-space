---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import DocsLayout from '@/layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const docs = (await getCollection('docs')) as CollectionEntry<'docs'>[];

  return docs
    .filter((doc) => !doc.data.draft)
    .map((doc) => ({
      params: { slug: doc.slug },
      props: { doc },
    }));
}

interface Props {
  doc: CollectionEntry<'docs'>;
}

const { doc } = Astro.props;
const { Content } = await doc.render();
---

<DocsLayout title={`${doc.data.title} | Liuying Space`} description={doc.data.description}>
  <header class="space-y-4 border-b border-white/10 pb-6">
    <p class="text-sm text-slate-400">{doc.data.category} · {doc.data.pubDate.toLocaleDateString('zh-CN')}</p>
    <h1 class="font-display text-3xl font-semibold text-white sm:text-4xl">{doc.data.title}</h1>
    <p class="text-base leading-8 text-slate-300">{doc.data.description}</p>
  </header>
  <div class="prose mt-8">
    <Content />
  </div>
</DocsLayout>
