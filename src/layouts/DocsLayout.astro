---
import BaseLayout from '@/layouts/BaseLayout.astro';

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <section class="section-shell py-16 sm:py-20">
    <div class="grid gap-10 lg:grid-cols-[240px_minmax(0,1fr)]">
      <aside class="glass-card rounded-3xl p-5">
        <p class="text-sm uppercase tracking-[0.3em] text-sky-300/80">Sections</p>
        <p class="mt-3 text-sm text-slate-300">Sidebar navigation is reserved for later series organization.</p>
      </aside>
      <article class="glass-card rounded-3xl p-6 sm:p-10">
        <slot />
      </article>
    </div>
  </section>
</BaseLayout>