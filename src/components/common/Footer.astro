---
import { profile } from '@/data/profile';
---

<footer class="border-t border-white/8">
  <div class="section-shell py-8 text-sm text-slate-400 sm:flex sm:items-center sm:justify-between">
    <p>© 2026 {profile.name}. All rights reserved.</p>
    <div class="mt-4 flex flex-wrap gap-4 sm:mt-0">
      {profile.socials.map((item) => (
        <a href={item.href} class="hover:text-slate-200" target="_blank" rel="noreferrer">
          {item.label}
        </a>
      ))}
    </div>
  </div>
</footer>