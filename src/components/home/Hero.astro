---
import { profile } from '@/data/profile';
import { withBase } from '@/utils/url';
---

<section class="section-shell py-16 sm:py-24">
  <div class="grid gap-10 lg:grid-cols-[1.25fr_0.75fr] lg:items-center">
    <div class="space-y-6">
      <p class="text-sm uppercase tracking-[0.3em] text-sky-300/80">Portfolio / Blog / Docs</p>
      <h1 class="font-display text-4xl font-semibold tracking-tight text-white sm:text-5xl lg:text-6xl">
        {profile.name}
      </h1>
      <p class="max-w-2xl text-lg text-slate-300 sm:text-xl">{profile.role}</p>
      <p class="max-w-2xl text-base leading-8 text-slate-400">{profile.summary}</p>
      <div class="flex flex-wrap gap-3">
        <a href={withBase('/projects/')} class="rounded-full bg-sky-400 px-5 py-3 text-sm font-semibold text-slate-950">
          View projects
        </a>
        <a href={withBase('/blog/')} class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold text-white">
          Read blog
        </a>
      </div>
    </div>
    <div class="glass-card rounded-3xl p-6 sm:p-8">
      <div class="flex items-center gap-5">
        <div class="grid size-20 shrink-0 place-items-center overflow-hidden rounded-2xl border border-white/10 bg-sky-400/10 text-2xl font-semibold text-sky-200">
          {profile.avatarImage ? <img src={withBase(profile.avatarImage)} alt={profile.avatarAlt} class="size-full object-cover" /> : profile.initials}
        </div>
        <div class="space-y-2">
          <p class="text-sm uppercase tracking-[0.3em] text-sky-300/70">Now</p>
          <p class="font-display text-2xl text-white">Static-first, content-driven, personal web presence.</p>
        </div>
      </div>
      <div class="mt-5 space-y-4">
        <p class="text-sm leading-7 text-slate-300">
          This site will grow into a portfolio, a blog, and a documentation hub with reusable components.
        </p>
      </div>
    </div>
  </div>
</section>
