---
import type { timeline } from '@/data/timeline';

interface Props {
  items: typeof timeline;
}

const { items } = Astro.props;
---

<div class="space-y-4">
  {items.map((item) => (
    <div class="glass-card rounded-2xl p-5">
      <p class="text-sm text-sky-300">{item.year}</p>
      <h3 class="mt-1 text-lg font-semibold text-white">{item.title}</h3>
      <p class="mt-2 text-sm leading-7 text-slate-300">{item.description}</p>
    </div>
  ))}
</div>
